  // Chunked loading for performance
  chunkedLoading: true,
  
  // Custom icon function
  iconCreateFunction: (cluster) => {
    const count = cluster.getChildCount();
    const size = count < 10 ? 'small' : count < 100 ? 'medium' : 'large';
    return createClusterIcon(count, size);
  },
};
